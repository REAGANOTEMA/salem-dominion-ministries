# Allow access to uploaded files
Options +Indexes

# Set proper MIME types
<Files "*.jpg">
    ForceType image/jpeg
</Files>
<Files "*.jpeg">
    ForceType image/jpeg
</Files>
<Files "*.png">
    ForceType image/png
</Files>
<Files "*.gif">
    ForceType image/gif
</Files>
<Files "*.mp3">
    ForceType audio/mpeg
</Files>
<Files "*.mp4">
    ForceType video/mp4
</Files>
<Files "*.wav">
    ForceType audio/wav
</Files>

# Prevent direct access to PHP files
<Files "*.php">
    Order allow,deny
    Deny from all
</Files>
