# --- Enable URL rewriting ---
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /salem-dominion-ministries/

    # Set directory index priority - PHP files first
    DirectoryIndex index.php index.html

    # Handle API requests - route directly to api.php
    RewriteCond %{REQUEST_URI} ^/salem-dominion-ministries/api\.php$ [NC]
    RewriteRule ^ - [L]

    RewriteCond %{QUERY_STRING} ^route= [NC]
    RewriteRule ^ api.php [L]

    # Serve existing files and directories directly
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Route everything else to index.php
    RewriteRule . index.php [L]
</IfModule>

# --- Prevent access to sensitive files ---
<FilesMatch "\.(htaccess|htpasswd|ini|env|log)$">
    Require all denied
</FilesMatch>

# --- Ensure proper MIME types ---
<IfModule mod_mime.c>
    AddType application/javascript .js
    AddType application/json .json
    AddType text/css .css
    AddType image/svg+xml .svg
    AddType image/png .png
    AddType image/jpeg .jpg .jpeg
    AddType image/gif .gif
    AddType image/x-icon .ico
    AddType font/woff2 .woff2
    AddType font/woff .woff
    AddType font/ttf .ttf
    AddType font/eot .eot
    AddType application/manifest+json .webmanifest
</IfModule>

# --- Security Headers ---
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
</IfModule>

# --- Cache static assets ---
<IfModule mod_expires.c>
    ExpiresActive On
    
    <FilesMatch "\.(js|css|svg|woff|woff2|png|jpg|jpeg|gif|ico)$">
        ExpiresDefault "access plus 1 year"
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    
    <FilesMatch "\.(html|json|webmanifest|php)$">
        ExpiresDefault "access plus 0 seconds"
        Header set Cache-Control "no-cache, no-store, must-revalidate"
    </FilesMatch>
</IfModule>

# --- Gzip Compression ---
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json application/xml
</IfModule>