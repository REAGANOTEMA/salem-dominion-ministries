# Enable URL rewriting
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /salem-dominion-ministries/

    # Allow direct access to existing files or directories
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Redirect all other requests to index.html (SPA fallback)
    RewriteRule ^ index.html [L]
</IfModule>

# Optional: Prevent access to sensitive files
<FilesMatch "\.(htaccess|htpasswd|ini|env|json)$">
    Require all denied
</FilesMatch>