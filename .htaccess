# --- Enable URL rewriting ---
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /salem-dominion-ministries/

    # Route API requests to index.php
    RewriteCond %{REQUEST_URI} ^/salem-dominion-ministries/api/.*$ [NC]
    RewriteRule ^api/(.*)$ index.php [L,QSA]

    # Serve existing files normally (JS, CSS, images, etc.)
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Redirect everything else to index.php (SPA fallback)
    RewriteRule . index.php [L]
</IfModule>

# --- Prevent access to sensitive files ---
<FilesMatch "\.(htaccess|htpasswd|ini|env)$">
    Require all denied
</FilesMatch>

# --- Ensure proper MIME types for JS modules and JSON ---
AddType application/javascript .js
AddType application/json .json
AddType text/css .css
AddType image/svg+xml .svg
AddType font/woff2 .woff2
AddType font/woff .woff

# --- Optional: Cache static assets for faster loading ---
<IfModule mod_expires.c>
    <FilesMatch "\.(js|css|svg|woff|woff2|png|jpg|jpeg|gif)$">
        ExpiresActive On
        ExpiresDefault "access plus 1 year"
    </FilesMatch>
</IfModule>